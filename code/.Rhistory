diet_tse,
output = diet_output_dir,
formula = '~ time * meal_group',
normalization = 'TSS',
transform = 'LOG',
augment = TRUE,
standardize = TRUE,
max_significance = 0.1,
median_comparison_abundance = TRUE,
median_comparison_prevalence = FALSE,
max_pngs = 100,
cores = 1,
save_models = TRUE,
verbosity = "WARN"
)
