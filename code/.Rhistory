top_bottom_corr <- result %>%
arrange(desc(cor)) %>%
slice_head(n = 5) %>%
bind_rows(
result %>%
arrange(cor) %>%
slice_head(n = 5)
)
ggplot(top_bottom_corr, aes(x = cor, y = reorder(paste(mirobes, SCFAs, sep = " vs "), cor))) +
geom_point(aes(color = cor > 0), size = 3) +
labs(
title = "Top 5 and Bottom 5 Correlations",
x = "Correlation",
y = "Microbe vs Variable"
) +
scale_color_manual(values = c("red", "blue"), labels = c("Negative", "Positive")) +
theme_minimal()
