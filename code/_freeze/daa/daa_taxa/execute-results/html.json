\\",\\\", \\\".\\\", null);\\n  }\"},{\"targets\":3,\"render\":\"function(data, type, row, meta) {\\n    return type !== 'display' ? data : DTWidget.formatSignif(data, 3, 3, \\\",\\\", \\\".\\\", null);\\n  }\"},{\"className\":\"dt-right\",\"targets\":[3,4,5]},{\"name\":\"feature\",\"targets\":0},{\"name\":\"metadata\",\"targets\":1},{\"name\":\"value\",\"targets\":2},{\"name\":\"coef\",\"targets\":3},{\"name\":\"qval_individual\",\"targets\":4},{\"name\":\"qval_joint\",\"targets\":5},{\"name\":\"model\",\"targets\":6}],\"order\":[],\"autoWidth\":false,\"orderClasses\":false,\"lengthMenu\":[6,10,25,50,100]}},\"evals\":[\"options.columnDefs.0.render\",\"options.columnDefs.1.render\",\"options.columnDefs.2.render\"],\"jsHooks\":[]}</script>\n```\n\n::: {.cell}\n\n:::\n\n\n\n\n## Summary plots\n\nThis plots contain a combined coefficient plot and heatmap of the most significant association between microbial features (listed on the y-axis) and different dietary conditions over time.\n\nThe coef plot shows the estimated effect sizes (β coefficients) for different microbial features.\n\n-   Circles (○) represent associations based on abundance.\n-   Triangles (△) represent associations based on prevalence.\n\nThe purple color represents the significance level (FDR-adjusted p-value) for abundance. The teal color represents the significance level (FDR-adjusted p-value) for prevalence.Darker colors indicate more significant associations.Error bars show uncertainty in the estimates.\n\nThe heatmap summarizes how different microbes are affected. Blue/Red coloring represents the effect sizes:\n\n-   Dark blue: Strong negative association.\n-   Light blue: Weak negative association.\n-   Light red: Weak positive association.\n-   Dark red: Strong positive association.\n-   Gray (NA): No data.\n\nAsterisks (*) indicate significant associations: -* (p \\< 0.1) - \\*\\* (p \\< 0.01)\n\n### species\n\n![taxa_image18](../../output/daa/daa_taxa/species/figures/summary_plot.png)\n\n### family\n\n![taxa_image5](../../output/daa/daa_taxa/family/figures/summary_plot.png)\\\n\n### genus\n\n![taxa_image13](../../output/daa/daa_taxa/genus/figures/summary_plot.png)\\\n\n### phylum\n\n![taxa_image14](../../output/daa/daa_taxa/phylum/figures/summary_plot.png)\\\n\n## Associations plots\n\nBox plots are used for categorical data abundance associations. Grids are used for categorical data prevalence associations. Data points plotted are after filtering, normalization, and transformation so that the scale in the plot is the scale that was used in fitting.\n\n### Associations-species\n\n![32](../../output/daa/daa_taxa/species/figures/association_plots/diet/linear/diet_Waltera_intestinalis_linear.png)  \n![33](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Adlercreutzia_equolifaciens_logistic.png)  \n![34](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Agathobaculum_butyriciproducens_logistic.png)  \n![35](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Alistipes_communis_logistic.png)  \n![36](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Bacteroides_ovatus_logistic.png)  \n![37](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Clostridium_sp_AF34_10BH_logistic.png)  \n![38](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Dorea_longicatena_logistic.png)  \n![39](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Dysosmobacter_welbionis_logistic.png)  \n![40](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Eubacterium_rectale_logistic.png)  \n![41](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Evtepia_gabavorous_logistic.png)  \n![42](../../output/daa/daa_taxa/species/figures/association_plots/diet/logistic/diet_Faecalibacillus_faecis_logistic.png)  \n![43](../../output/daa/daa_taxa/s